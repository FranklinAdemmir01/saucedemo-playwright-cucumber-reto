# ========================================
# ENVIRONMENT CONFIGURATION
# ========================================
# Select the environment to run tests against
# 
# Available options:
#   - dev         : Development (4 workers, retries enabled, videos ON, headless OFF by default)
#   - qa          : QA/Testing (4 workers, retries enabled, videos ON, headless ON)
#   - prod        : Production (2 workers, no retries, videos OFF, headless ON always)
#
# Usage examples:
#   ENV=dev npm test                    # Run with development settings
#   ENV=qa npm test                     # Run with QA settings
#   ENV=prod npm test                   # Run with production settings
#   ENV=qa npm run test:smoke          # Run smoke tests in QA environment
#   ENV=prod npm run test:any '@tag'   # Run tagged tests in production
#
# You can also override in command line:
#   ENV=prod WORKERS=4 npm test        # Production with 4 workers
#
# Default: dev
ENV=dev

# ========================================
# APPLICATION CONFIGURATION
# ========================================
BASE_URL=https://www.saucedemo.com

# Browser Configuration
BROWSER=chromium
HEADLESS=true
SLOW_MO=0
TIMEOUT=30000

# Test Execution Configuration
# Number of parallel workers (default: from environment config)
# dev: 4, qa: 4, prod: 2
WORKERS=4
# Number of retry attempts (default: from environment config)
# dev: 2, qa: 2, prod: 0
RETRY_ATTEMPTS=2

# Test Users
STANDARD_USER=standard_user
LOCKED_USER=locked_out_user
PASSWORD=secret_sauce

# Checkout Default Data
CHECKOUT_FIRST_NAME=John
CHECKOUT_LAST_NAME=Doe
CHECKOUT_POSTAL_CODE=12345

# Screenshot and Video Configuration
SCREENSHOT_ON_FAILURE=true
VIDEO_ON_FAILURE=true
ENABLE_TRACING=false

# Report Configuration
REPORT_TITLE=SauceDemo Automation Test Report
REPORT_NAME=Playwright-Cucumber Testing Framework

# ========================================
# Environment-Specific Defaults
# ========================================
# 
# DEV (development):
#   - Headless: false
#   - Workers: 4
#   - Retries: 2
#   - Timeouts: 30s / 10s / 60s (default/short/long)
#   - Videos: true, Screenshots: true
#   - Logging: info level
#
# QA (test):
#   - Headless: true
#   - Workers: 4
#   - Retries: 2
#   - Timeouts: 30s / 10s / 60s
#   - Videos: true, Screenshots: true
#   - Logging: info level
#
# PROD (production):
#   - Headless: true (always)
#   - Workers: 2
#   - Retries: 0 (fail fast)
#   - Timeouts: 20s / 5s / 40s
#   - Videos: false, Screenshots: true
#   - Logging: warn level
#